{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sts2-ritsulib.ritsukage.com/schemas/telemetry/v1/telemetry-event.schema.json",
  "title": "RitsuLib telemetry event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "applicantId",
    "eventName",
    "requestId",
    "category",
    "timestampUtc",
    "properties"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "ritsulib.telemetry.v1"
    },
    "applicantId": {
      "type": "string",
      "minLength": 1,
      "description": "Applicant id that owns the destination endpoint."
    },
    "eventName": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "session_start",
        "mod_inventory",
        "run_history.completed",
        "exception"
      ]
    },
    "requestId": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "basic_usage",
        "mod_inventory",
        "run_history",
        "diagnostics"
      ]
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "BasicUsage",
        "ModInventory",
        "RunHistory",
        "Diagnostics"
      ]
    },
    "timestampUtc": {
      "type": "string",
      "format": "date-time"
    },
    "properties": {
      "type": "object",
      "additionalProperties": true,
      "description": "Flat event metadata. Backends should index these fields first.",
      "properties": {
        "anonymous_install_id": {
          "type": "string",
          "description": "Stable anonymous install id generated by RitsuLib."
        },
        "session_id": {
          "type": "string",
          "description": "Per-process session id generated by RitsuLib."
        },
        "ritsulib_version": {
          "type": "string"
        },
        "ritsulib_informational_version": {
          "type": "string"
        },
        "ritsulib_build_channel": {
          "type": "string",
          "examples": [
            "release",
            "dev",
            "local_debug"
          ]
        },
        "ritsulib_build_configuration": {
          "type": "string",
          "examples": [
            "Release",
            "Debug"
          ]
        },
        "applicant_id": {
          "type": "string"
        },
        "owner_mod_id": {
          "type": "string"
        },
        "applicant_display_name": {
          "type": "string"
        },
        "game_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "game_release_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "type": "string"
        },
        "os_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "os_version": {
          "type": "string"
        },
        "process_architecture": {
          "type": "string"
        },
        "dotnet_runtime": {
          "type": "string"
        },
        "game_language": {
          "type": [
            "string",
            "null"
          ]
        },
        "startup_snapshot_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "registered_mod_count": {
          "type": "integer",
          "minimum": 0
        },
        "loaded_mod_count": {
          "type": "integer",
          "minimum": 0
        },
        "disabled_mod_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_mod_count": {
          "type": "integer",
          "minimum": 0
        },
        "added_at_runtime_mod_count": {
          "type": "integer",
          "minimum": 0
        },
        "gameplay_mod_count": {
          "type": "integer",
          "minimum": 0
        },
        "payload_kind": {
          "type": "string",
          "examples": [
            "vanilla_run_history",
            "exception"
          ]
        },
        "json_indented": {
          "type": "boolean"
        },
        "is_victory": {
          "type": "boolean"
        },
        "is_abandoned": {
          "type": "boolean"
        },
        "occurred_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "run_game_mode": {
          "type": "string"
        },
        "run_is_daily": {
          "type": "boolean"
        },
        "run_player_count": {
          "type": "integer",
          "minimum": 0
        },
        "run_floor_reached": {
          "type": "integer"
        },
        "run_ascension": {
          "type": "integer"
        },
        "run_time_seconds": {
          "type": "number"
        },
        "run_win_time_seconds": {
          "type": "number"
        },
        "run_reload_count": {
          "type": "integer",
          "minimum": 0
        },
        "run_character_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capture_source": {
          "type": "string"
        },
        "exception_type": {
          "type": "string"
        }
      }
    },
    "payload": {
      "description": "Structured event data. Common object members include base_payload, private_contributions, shared_contributions, and applicant_payload. Keep full payloads here and promote query-critical fields into properties.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array"
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
