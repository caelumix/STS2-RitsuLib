  "RitsuLib bilingual summary with cref": {
    "scope": "csharp",
    "prefix": "docbic",
    "description": "Bilingual XML doc summary with see cref",
    "body": [
      "/// <summary>",
      "/// <para xml:lang=\"en\">${1:Summary referencing} <see cref=\"${2:TypeName}\" />.</para>",
      "/// <para xml:lang=\"zh-CN\">${3:中文摘要，引用} <see cref=\"$2\" />。</para>",
      "/// </summary>"
    ]
  }
}
