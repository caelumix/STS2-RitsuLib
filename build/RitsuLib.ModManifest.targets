<Project>
  <PropertyGroup>
    <RitsuLibManifestToolSource>$(MSBuildProjectDirectory)\build\GenerateModManifest.cs</RitsuLibManifestToolSource>
    <_RitsuLibManifestToolOutputDir>$(IntermediateOutputPath)ritsulib-mod-manifest-tool\$(Configuration)</_RitsuLibManifestToolOutputDir>
    <_RitsuLibManifestToolDll>$(_RitsuLibManifestToolOutputDir)\GenerateModManifest.dll</_RitsuLibManifestToolDll>
  </PropertyGroup>

  <Target
      Name="GenerateRitsuLibModManifest"
      BeforeTargets="Build;Pack"
      Condition="'$(RitsuLibSkipManifestGeneration)' != 'true' and '$(RitsuLibManifestGenerationInProgress)' != 'true' and '$(DesignTimeBuild)' != 'true'"
      Inputs="$(RitsuLibManifestSource);$(RitsuLibManifestToolSource)"
      Outputs="$(RitsuLibManifestGenerated)">
    <Error
        Condition="!Exists('$(RitsuLibManifestSource)')"
        Text="Missing manifest source file: '$(RitsuLibManifestSource)'"/>
    <Error
        Condition="!Exists('$(RitsuLibManifestToolSource)')"
        Text="Missing manifest tool source file: '$(RitsuLibManifestToolSource)'"/>

    <PropertyGroup>
      <RitsuLibManifestGenerationInProgress>true</RitsuLibManifestGenerationInProgress>
      <RitsuLibManifestMinGameVersion Condition="'$(RitsuLibManifestMinGameVersion)' == ''">$(Sts2ApiCompat)</RitsuLibManifestMinGameVersion>
    </PropertyGroup>

    <MakeDir Directories="$(_RitsuLibManifestToolOutputDir)"/>

    <Exec
        WorkingDirectory="$([System.IO.Path]::GetTempPath())"
        Command="dotnet build &quot;$(RitsuLibManifestToolSource)&quot; -c $(Configuration) -o &quot;$(_RitsuLibManifestToolOutputDir)&quot; -v q --nologo"/>

    <Error
        Condition="!Exists('$(_RitsuLibManifestToolDll)')"
        Text="Manifest tool DLL not found (build failed?): $(_RitsuLibManifestToolDll)"/>

    <Exec
        WorkingDirectory="$([System.IO.Path]::GetTempPath())"
        Command="dotnet exec &quot;$(_RitsuLibManifestToolDll)&quot; generate &quot;$(RitsuLibManifestSource)&quot; &quot;$(RitsuLibManifestGenerated)&quot; &quot;$(RitsuLibModDisplayName)&quot; &quot;$(RitsuLibManifestMinGameVersion)&quot;"/>
  </Target>
</Project>
