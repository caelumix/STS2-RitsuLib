{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BAKAOLC/STS2-RitsuLib/main/schemas/mod-settings/runtime-interop/v1/schema.json",
  "title": "RitsuLib Runtime Interop mod settings mirror",
  "description": "Payload shape returned by static CreateRitsuLibSettingsSchema() and parsed by RuntimeInteropMirrorSource. Recommended root: modId + pages[]. JSON property names are matched case-insensitively at runtime; this schema uses camelCase. Entry \"type\" values are also case-insensitive in C#; most branches here use lowercase literals for validation.",
  "oneOf": [
    {
      "$ref": "#/$defs/multiPageDocument"
    },
    {
      "$ref": "./legacy-single-page.schema.json"
    }
  ],
  "$defs": {
    "text": {
      "title": "Text value (literal or localized)",
      "description": "UI text source. Accepts a plain string (literal) for backward compatibility, or an object describing a localized source (langMap / i18n / locString).",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/textObject"
        }
      ]
    },
    "textObject": {
      "type": "object",
      "oneOf": [
        {
          "title": "Language map",
          "properties": {
            "langMap": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "string"
              },
              "description": "Map from language code to string. The runtime uses best-effort matching (exact, prefix match, then 'en', then any entry)."
            },
            "fallback": {
              "type": "string",
              "description": "Fallback text when no entry matches."
            }
          },
          "required": ["langMap"],
          "additionalProperties": true
        },
        {
          "title": "I18N key",
          "properties": {
            "i18n": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string",
                  "minLength": 1
                },
                "fallback": {
                  "type": "string"
                }
              },
              "required": ["key"],
              "additionalProperties": true
            },
            "fallback": {
              "type": "string",
              "description": "Optional fallback when i18n.fallback is omitted."
            }
          },
          "required": ["i18n"],
          "additionalProperties": true
        },
        {
          "title": "Game LocString",
          "properties": {
            "locString": {
              "type": "object",
              "properties": {
                "table": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Localization table name, e.g. settings_ui."
                },
                "key": {
                  "type": "string",
                  "minLength": 1
                },
                "fallback": {
                  "type": "string"
                }
              },
              "required": ["table", "key"],
              "additionalProperties": true
            }
          },
          "required": ["locString"],
          "additionalProperties": true
        }
      ],
      "additionalProperties": true
    },
    "i18nSource": {
      "title": "I18N sources (explicit)",
      "description": "Explicit translation sources for resolving i18n keys. If omitted, i18n objects are treated as literal fallback at runtime.",
      "type": "object",
      "properties": {
        "instanceName": {
          "type": "string",
          "description": "Optional I18N instance name for logging."
        },
        "fsFolders": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "File-system folders containing <lang>.json (e.g. user://mod-configs/<modId>/localization)."
        },
        "resourceFolders": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Embedded resource folder prefixes containing <folder>.<lang>.json."
        },
        "pckFolders": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "PCK folders containing <lang>.json (e.g. res://MyMod/localization)."
        },
        "resourceAssembly": {
          "type": "string",
          "description": "Optional assembly name for embedded resource loading. When omitted, the provider type's assembly is used."
        }
      },
      "additionalProperties": true
    },
    "multiPageDocument": {
      "title": "Multi-page document",
      "type": "object",
      "required": ["modId", "pages"],
      "properties": {
        "modId": {
          "type": "string",
          "minLength": 1,
          "description": "Target mod id for mirrored settings pages."
        },
        "modDisplayName": {
          "$ref": "#/$defs/text",
          "description": "Optional display name in the mod settings sidebar."
        },
        "modSidebarOrder": {
          "type": "integer",
          "description": "Optional sidebar ordering hint."
        },
        "i18nSource": {
          "$ref": "#/$defs/i18nSource",
          "description": "Optional explicit I18N sources used by { i18n: { key } } text objects."
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/page"
          }
        }
      },
      "additionalProperties": true
    },
    "page": {
      "type": "object",
      "required": ["sections"],
      "properties": {
        "i18nSource": {
          "$ref": "#/$defs/i18nSource",
          "description": "Optional I18N source override for this page and its children."
        },
        "pageId": {
          "type": "string",
          "description": "Defaults to \"interop\" when empty or omitted."
        },
        "parentPageId": {
          "type": "string",
          "description": "Optional parent page id for nested pages."
        },
        "title": {
          "$ref": "#/$defs/text",
          "description": "Defaults to \"Settings\" when empty or omitted."
        },
        "description": {
          "$ref": "#/$defs/text"
        },
        "sortOrder": {
          "type": "integer",
          "description": "Defaults to 10040 when omitted."
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      },
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "required": ["id", "entries"],
      "properties": {
        "i18nSource": {
          "$ref": "#/$defs/i18nSource",
          "description": "Optional I18N source override for this section and its children."
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "$ref": "#/$defs/text"
        },
        "description": {
          "$ref": "#/$defs/text"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry"
          }
        }
      },
      "additionalProperties": true
    },
    "entryBase": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "i18nSource": {
          "$ref": "#/$defs/i18nSource",
          "description": "Optional I18N source override for this entry."
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "description": "Matched case-insensitively. int-slider alias: intslider."
        },
        "key": {
          "type": "string",
          "description": "Storage key passed to GetRitsuLibSettingValue / SetRitsuLibSettingValue; defaults to id."
        },
        "label": {
          "$ref": "#/$defs/text",
          "description": "Defaults to id when empty or omitted."
        },
        "description": {
          "$ref": "#/$defs/text"
        },
        "defaultValue": {
          "description": "Optional default value. When GetRitsuLibSettingValue(key) returns null, RitsuLib may write back this value and save, then use it for UI display.",
          "oneOf": [
            { "type": "boolean" },
            { "type": "number" },
            { "type": "string" },
            { "type": "array" },
            { "type": "object" },
            { "type": "null" }
          ]
        },
        "scope": {
          "type": "string",
          "description": "Optional persistence scope hint. Recognized values (case-insensitive): \"global\", \"profile\", \"inMemory\" (aliases: in_memory/in-memory). Any other value is treated as \"global\"."
        },
        "visibleWhenMethod": {
          "type": "string",
          "description": "Optional static method on the provider type. Allowed signatures: Method() or Method(string key). Return value is coerced to bool; failures default to visible."
        }
      },
      "additionalProperties": true
    },
    "entry": {
      "oneOf": [
        {
          "title": "header",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "header"
                }
              }
            }
          ]
        },
        {
          "title": "paragraph",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "paragraph"
                },
                "maxBodyHeight": {
                  "type": "number",
                  "description": "Optional max body height for paragraph layout."
                }
              }
            }
          ]
        },
        {
          "title": "subpage",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "subpage"
                },
                "targetPageId": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Required; entries without this are skipped at runtime."
                },
                "buttonText": {
                  "$ref": "#/$defs/text"
                }
              },
              "required": ["targetPageId"]
            }
          ]
        },
        {
          "title": "toggle",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "toggle"
                }
              }
            }
          ]
        },
        {
          "title": "slider",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "slider"
                },
                "min": {
                  "type": "number",
                  "description": "Default 0; if max < min they are swapped at runtime."
                },
                "max": {
                  "type": "number",
                  "description": "Default 100."
                },
                "step": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "description": "Values <= 0 are treated as 1 at runtime."
                }
              }
            }
          ]
        },
        {
          "title": "int-slider",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "type": "string",
                  "pattern": "^([Ii][Nn][Tt]-[Ss][Ll][Ii][Dd][Ee][Rr]|[Ii][Nn][Tt][Ss][Ll][Ii][Dd][Ee][Rr])$",
                  "description": "int-slider or intslider; casing ignored at runtime."
                },
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "step": {
                  "type": "number",
                  "description": "Rounded to int; minimum step 1 after coercion at runtime."
                }
              }
            }
          ]
        },
        {
          "title": "choice",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "choice"
                },
                "defaultValue": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Optional default option value written back when missing (Get returns null). Must match one of options[].value (or string option)."
                },
                "presentation": {
                  "type": "string",
                  "description": "String \"dropdown\" (case-insensitive) uses dropdown UI; any other value uses stepper."
                },
                "options": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "oneOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "object",
                        "required": ["value"],
                        "properties": {
                          "value": {
                            "type": "string",
                            "minLength": 1
                          },
                          "i18nSource": {
                            "$ref": "#/$defs/i18nSource",
                            "description": "Optional I18N source override for resolving this option label."
                          },
                          "label": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    ]
                  },
                  "description": "Empty options list causes the entry to be skipped at runtime."
                },
                "optionsMethod": {
                  "type": "string",
                  "description": "Optional static method on the provider type. Allowed signatures: Method() or Method(string key). Should return an enumerable of strings or { value, label } objects. Falls back to static options on failure."
                }
              },
              "required": ["options"]
            }
          ]
        },
        {
          "title": "string",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "string"
                },
                "placeholder": {
                  "$ref": "#/$defs/text"
                },
                "maxLength": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Values < 1 are ignored at runtime (treated as no limit)."
                }
              }
            }
          ]
        },
        {
          "title": "multiline-string",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "enum": ["multiline-string", "multiline"]
                },
                "placeholder": {
                  "$ref": "#/$defs/text"
                },
                "maxLength": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          ]
        },
        {
          "title": "color",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "color"
                },
                "editAlpha": {
                  "type": "boolean",
                  "description": "Default true when omitted."
                },
                "editIntensity": {
                  "type": "boolean",
                  "description": "Default false when omitted."
                }
              }
            }
          ]
        },
        {
          "title": "key-binding",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "enum": ["key-binding", "keybinding"]
                },
                "allowModifierCombos": {
                  "type": "boolean",
                  "description": "Default true when omitted."
                },
                "allowModifierOnly": {
                  "type": "boolean",
                  "description": "Default true when omitted."
                },
                "distinguishModifierSides": {
                  "type": "boolean",
                  "description": "Default false when omitted."
                }
              }
            }
          ]
        },
        {
          "title": "info-card",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "enum": ["info-card", "infocard"]
                },
                "body": {
                  "$ref": "#/$defs/text",
                  "description": "Card body text (rich-text); may be empty."
                }
              }
            }
          ]
        },
        {
          "title": "runtime-hotkey-summary",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "enum": [
                    "runtime-hotkey-summary",
                    "runtimehotkeysummary",
                    "hotkey-summary"
                  ]
                },
                "body": {
                  "$ref": "#/$defs/text",
                  "description": "Descriptive text under the title."
                },
                "bindings": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "#/$defs/text"
                  },
                  "description": "Right-hand binding chip labels; empty list skips registration at runtime."
                },
                "idSuffix": {
                  "$ref": "#/$defs/text",
                  "description": "Optional ModSettingsText id suffix passed to AddRuntimeHotkeySummary."
                }
              },
              "required": ["bindings"]
            }
          ]
        },
        {
          "title": "button",
          "allOf": [
            {
              "$ref": "#/$defs/entryBase"
            },
            {
              "properties": {
                "type": {
                  "const": "button"
                },
                "buttonText": {
                  "$ref": "#/$defs/text",
                  "description": "Defaults to label when omitted for the button caption."
                },
                "tone": {
                  "type": "string",
                  "description": "Only \"accent\" or \"danger\" (case-insensitive) change button tone; otherwise normal."
                }
              }
            }
          ]
        }
      ]
    }
  }
}
