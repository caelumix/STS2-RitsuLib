{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sts2-ritsulib.ritsukage.com/schemas/telemetry/v1/telemetry-batch.schema.json",
  "title": "RitsuLib telemetry batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "applicant_id",
    "events"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "ritsulib.telemetry.batch.v1"
    },
    "applicant_id": {
      "type": "string",
      "minLength": 1,
      "description": "Applicant id for the destination adapter."
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "$ref": "./telemetry-event.schema.json"
      }
    }
  }
}
