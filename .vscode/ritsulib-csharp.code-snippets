    "scope": "csharp",
    "prefix": "docbi",
    "description": "Bilingual XML doc summary with xml:lang paras",
    "body": [
      "/// <summary>",
      "/// <para xml:lang=\"en\">${1:English summary.}</para>",
      "/// <para xml:lang=\"zh-CN\">${2:中文摘要。}</para>",
